PORT=4000
# Use a role that exists on your machine. Homebrew Postgres on macOS often uses your macOS username, not "postgres".
# Examples:
#   postgresql://YOUR_USERNAME@localhost:5432/sia_academy
#   postgresql://YOUR_USERNAME:yourpassword@localhost:5432/sia_academy
DATABASE_URL=postgresql://YOUR_USERNAME@localhost:5432/sia_academy
FRONTEND_ORIGIN=http://localhost:5173
